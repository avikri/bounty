rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ── helpers ─────────────────────────────────────────────────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMember(gid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid));
    }

    function isOwner(gid) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/groups/$(gid)).data.ownerId == request.auth.uid;
    }

    function isAdmin(gid) {
      return isSignedIn() && isMember(gid) &&
        get(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    /* ── users ───────────────────────────────────────────────────── */
    match /users/{userId} {
      // Self-only read: the client only ever reads its own user doc; all
      // other profile data comes from the per-group `members` subcollection
      // (gated by isMember). This blocks full user-base enumeration.
      allow read: if isSelf(userId);
      // totalPoints is a Cloud-Function-maintained aggregate; clients may seed
      // it to 0 on create and may only edit their own profile fields. groupIds
      // is written exclusively by createGroup / joinGroup (Cloud Functions).
      allow create: if isSelf(userId)
                     && request.resource.data.totalPoints == 0;
      allow update: if isSelf(userId)
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['displayName', 'handle', 'photoURL']);
      allow delete: if false;
    }

    /* ── groups ──────────────────────────────────────────────────── */
    match /groups/{gid} {
      allow read:   if isMember(gid);
      // Group creation goes through the createGroup Cloud Function only, which
      // also provisions the owner's members doc + leaderboard atomically and
      // allocates a unique invite code. A direct client create would otherwise
      // let users spam orphan groups and squat invite codes.
      allow create: if false;
      // Owners/admins may edit display settings only. ownerId, inviteCode,
      // memberCount, etc. are off-limits — otherwise an admin could rewrite
      // ownerId and take over the group.
      allow update: if (isOwner(gid) || isAdmin(gid))
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['name', 'emoji', 'defaultExpiryDays']);
      allow delete: if isOwner(gid);

      /* members subcollection */
      match /members/{userId} {
        allow read: if isMember(gid);
        // Membership is granted only through the joinGroup / createGroup Cloud
        // Functions (which validate the invite code). No client self-create —
        // otherwise any signed-in user could add themselves to any group and
        // read all of its bounties.
        allow create: if false;
        // Owners may change a member's role only. points/wins/losses and the
        // cached profile fields are written exclusively by Cloud Functions, so
        // a member cannot promote themselves or forge their leaderboard score.
        allow update: if isOwner(gid)
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']);
        // A member can leave; an owner can remove members.
        allow delete: if isOwner(gid) || isSelf(userId);
      }

      /* bounties */
      match /bounties/{bid} {
        allow read:   if isMember(gid);
        // Lock the field set and validate every client-settable value. price
        // feeds points / leaderboard / IOU amounts server-side, so it must be
        // a bounded positive integer — never client-forged, negative, or
        // non-numeric. createdAt must be the server time (blocks feed-pinning
        // via a forged future timestamp); expiresAt must be a timestamp.
        allow create: if isMember(gid)
                       && request.resource.data.keys().hasOnly(
                            ['title', 'description', 'price', 'currency',
                             'state', 'posterId', 'claimantId',
                             'expiresAt', 'createdAt'])
                       && request.resource.data.posterId == request.auth.uid
                       && request.resource.data.state == 'available'
                       && request.resource.data.claimantId == null
                       && request.resource.data.price is int
                       && request.resource.data.price >= 1
                       && request.resource.data.price <= 100000
                       && request.resource.data.title is string
                       && request.resource.data.title.size() > 0
                       && request.resource.data.title.size() <= 80
                       && request.resource.data.description is string
                       && request.resource.data.description.size() <= 1000
                       && request.resource.data.currency is string
                       && request.resource.data.currency.size() <= 8
                       && request.resource.data.expiresAt is timestamp
                       && request.resource.data.createdAt == request.time;
        // State transitions go through Cloud Functions only.
        allow update: if false;
        allow delete: if resource.data.posterId == request.auth.uid
                       && resource.data.state == 'available';

        /* activity timeline — append-only via CF */
        match /activity/{eventId} {
          allow read: if isMember(gid);
          allow write: if false;
        }
      }

      /* leaderboard summary — CF only */
      match /leaderboard/{docId} {
        allow read:  if isMember(gid);
        allow write: if false;
      }
    }

    /* ── IOUs ────────────────────────────────────────────────────── */
    match /ious/{iouId} {
      allow read: if isSignedIn()
                   && (resource.data.debtorId == request.auth.uid
                       || resource.data.creditorId == request.auth.uid);
      // Creation/settlement happen via Cloud Functions.
      allow write: if false;
    }

    /* ── notifications ───────────────────────────────────────────── */
    match /notifications/{userId}/inbox/{notifId} {
      allow read, update, delete: if isSelf(userId);
      // Creation by Cloud Functions only.
      allow create: if false;
    }

    /* ── rate-limit counters — Cloud Functions only ──────────────── */
    match /rateLimits/{userId} {
      allow read, write: if false;
    }
  }
}
